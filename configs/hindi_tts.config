{
  "train": {
    "log_interval": 200,
    "eval_interval": 1000,
    "seed": 1234,
    "epochs": 20000,
    "learning_rate": 0.0002,
    "betas": [
      0.8,
      0.99
    ],
    "eps": 1e-09,
    "batch_size": 24,
    "fp16_run": true,
    "lr_decay": 0.999875,
    "segment_size": 8192,
    "init_lr_ratio": 1,
    "warmup_epochs": 0,
    "c_mel": 45,
    "c_kl": 1.0
  },
  "data": {
    "training_files": "others/filelists/hindi_train.txt.cleaned",
    "validation_files": "others/filelists/hindi_val.txt.cleaned",
    "text_cleaners": [
      "indic_g2g_cleaners"
    ],
    "max_wav_value": 32768.0,
    "sampling_rate": 22050,
    "filter_length": 1024,
    "hop_length": 256,
    "win_length": 1024,
    "n_mel_channels": 80,
    "mel_fmin": 0.0,
    "mel_fmax": null,
    "add_blank": true,
    "max_text_len": 512,
    "cache_text": true,
    "bucket_by": "max",
    "text_length_weight": 6,
    "n_speakers": 0,
    "cleaned_text": false
  },
  "wandb": {
    "enabled": false,
    "project": "mamba-vits"
  },
  "vocoder": {
    "independent_finetune": false,
    "backend": "vocos",
    "phase_aware": true,
    "voiced_threshold": 10.0,
    "harmonic_num": 8
  },
  "model": {
    "inter_channels": 192,
    "hidden_channels": 192,
    "filter_channels": 768,
    "n_heads": 2,
    "n_layers": 6,
    "kernel_size": 3,
    "p_dropout": 0.1,
    "encoder_type": "mamba",
    "mamba_d_state": 16,
    "mamba_d_conv": 4,
    "mamba_expand": 2,
    "mamba_bidirectional": true,
    "mamba_use_ffn": true,
    "use_style_predictors": false,
    "style_predictor_style_dim": 128,
    "style_predictor_layers": 2,
    "style_predictor_max_duration": 512,
    "style_predictor_dropout": 0.1,
    "style_predictor_prosody_upsample": false,
    "resblock": "1",
    "resblock_kernel_sizes": [
      3,
      7,
      11
    ],
    "resblock_dilation_sizes": [
      [
        1,
        3,
        5
      ],
      [
        1,
        3,
        5
      ],
      [
        1,
        3,
        5
      ]
    ],
    "upsample_rates": [
      8,
      8,
      2,
      2
    ],
    "upsample_initial_channel": 512,
    "upsample_kernel_sizes": [
      16,
      16,
      4,
      4
    ],
    "n_layers_q": 3,
    "use_spectral_norm": false
  }
}
